{
  "name": "@pi9/subagent",
  "version": "0.2.0",
  "description": "Pi extension that adds subagent delegation.",
  "license": "MIT",
  "author": "Chase Cummings <chaseecummings@gmail.com>",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Chase-C/pi9_subagent.git"
  },
  "bugs": {
    "url": "https://github.com/Chase-C/pi9_subagent/issues"
  },
