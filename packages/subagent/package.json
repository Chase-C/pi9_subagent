{
  "name": "@pi9/subagent",
  "version": "0.1.0",
  "description": "Pi extension that adds subagent delegation, progress UI, and session management.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "agents",
    "README.md"
  ],
  "keywords": [
    "pi-package",
    "pi",
    "pi9",
    "subagent"
  ],
  "scripts": {
    "build": "tsc --build",
    "clean": "tsc --build --clean",
    "test": "vitest run",
